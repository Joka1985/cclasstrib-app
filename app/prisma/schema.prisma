  baseOficialClassificacao BaseOficialClassificacao? @relation(fields: [baseOficialClassificacaoId], references: [id], onDelete: SetNull)

  @@index([loteId])
  @@index([clienteId])
  @@index([statusDecisao])
  @@index([abaDestino])
  @@index([cst])
  @@index([cclassTrib])
  @@map("resultados_parametrizacao")
