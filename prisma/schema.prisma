generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoPessoa {
  PF
  PJ
}

enum StatusLote {
  CADASTRO_PENDENTE
  DOCUMENTACAO_PENDENTE
  AGUARDANDO_VALIDACAO
  ORCAMENTO_GERADO
  AGUARDANDO_PAGAMENTO
  PAGAMENTO_APROVADO
  EM_PROCESSAMENTO
  PROCESSADO_COM_SUCESSO
  PROCESSADO_COM_DIVERGENCIAS
  PROCESSADO_COM_REVISAO_HUMANA
  ERRO_PROCESSAMENTO
  EMAIL_ENVIADO
}

enum TipoDocumentoFiscal {
  NFE
  NFCE
  NFSE
  OUTRO
}

enum StatusXml {
  SAIDA
  ENTRADA
  NAO_RELACIONADO
  INVALIDO
}

model Cliente {
  id                 String     @id @default(cuid())
  tipoPessoa         TipoPessoa @map("tipo_pessoa")
  nomeRazaoSocial    String     @map("nome_razao_social")
  cpfCnpj            String     @unique @map("cpf_cnpj")
  atividadePrincipal String     @map("atividade_principal")
  email              String
  telefone           String?
  uf                 String?    @db.VarChar(2)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  lotes Lote[]

  @@map("clientes")
}

model Lote {
  id                        String     @id @default(cuid())
  clienteId                 String     @map("cliente_id")
  statusLote                StatusLote @default(DOCUMENTACAO_PENDENTE) @map("status_lote")
  quantidadeLinhasPlanilha  Int        @default(0) @map("quantidade_linhas_planilha")
  quantidadeLinhasValidas   Int        @default(0) @map("quantidade_linhas_validas")
  quantidadeLinhasInvalidas Int        @default(0) @map("quantidade_linhas_invalidas")
  valorUnitario             Decimal    @default(0) @map("valor_unitario") @db.Decimal(10, 2)
  valorTotal                Decimal    @default(0) @map("valor_total") @db.Decimal(12, 2)
  observacoesInternas       String?    @map("observacoes_internas")
  createdAt                 DateTime   @default(now()) @map("created_at")
  updatedAt                 DateTime   @updatedAt @map("updated_at")

  cliente                 Cliente                  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  itensPlanilha           ItemPlanilha[]
  xmlDocumentos           XmlDocumento[]
  divergenciasXmlPlanilha DivergenciaXmlPlanilha[]

  @@index([clienteId])
  @@index([statusLote])
  @@map("lotes")
}

model ItemPlanilha {
  id                     String   @id @default(cuid())
  loteId                 String   @map("lote_id")
  linhaOrigem            Int      @map("linha_origem")
  codigoItemOuServico    String   @map("codigo_item_ou_servico")
  descricaoItemOuServico String   @map("descricao_item_ou_servico")
  ncm                    String?
  nbs                    String?
  linhaValida            Boolean  @default(false) @map("linha_valida")
  motivoInvalidade       String?  @map("motivo_invalidade")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  lote Lote @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@index([loteId])
  @@index([linhaValida])
  @@map("itens_planilha")
}

model XmlDocumento {
  id                  String              @id @default(cuid())
  loteId              String              @map("lote_id")
  tipoDocumento       TipoDocumentoFiscal @default(NFE) @map("tipo_documento")
  chaveDocumento      String?             @map("chave_documento")
  emitenteCpfCnpj     String              @map("emitente_cpf_cnpj")
  emitenteNome        String?             @map("emitente_nome")
  destinatarioCpfCnpj String?             @map("destinatario_cpf_cnpj")
  destinatarioNome    String?             @map("destinatario_nome")
  dataEmissao         DateTime?           @map("data_emissao")
  statusXml           StatusXml           @default(INVALIDO) @map("status_xml")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  lote     Lote      @relation(fields: [loteId], references: [id], onDelete: Cascade)
  itensXml ItemXml[]

  @@index([loteId])
  @@index([statusXml])
  @@map("xml_documentos")
}

model ItemXml {
  id             String   @id @default(cuid())
  xmlDocumentoId String   @map("xml_documento_id")
  numeroItem     Int      @map("numero_item")
  codigoItem     String?  @map("codigo_item")
  descricaoItem  String   @map("descricao_item")
  ncm            String?
  cfop           String?
  quantidade     Decimal? @db.Decimal(14, 4)
  valorUnitario  Decimal? @map("valor_unitario") @db.Decimal(14, 4)
  valorTotal     Decimal? @map("valor_total") @db.Decimal(14, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  xmlDocumento XmlDocumento @relation(fields: [xmlDocumentoId], references: [id], onDelete: Cascade)

  @@index([xmlDocumentoId])
  @@index([codigoItem])
  @@index([ncm])
  @@map("itens_xml")
}

model DivergenciaXmlPlanilha {
  id                String   @id @default(cuid())
  loteId            String   @map("lote_id")
  codigoPlanilha    String?  @map("codigo_planilha")
  codigoXml         String?  @map("codigo_xml")
  descricaoPlanilha String?  @map("descricao_planilha")
  descricaoXml      String?  @map("descricao_xml")
  tipoDivergencia   String   @map("tipo_divergencia")
  observacao        String?  @map("observacao")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  lote Lote @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@index([loteId])
  @@index([tipoDivergencia])
  @@map("divergencias_xml_planilha")
}
